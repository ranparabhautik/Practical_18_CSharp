@model IEnumerable<Practical_18.Models.Entities.Student>

<h2>Students List</h2>

<p>
    <a asp-action="Create">Create New Student</a>
</p>

<table border="1" cellpadding="10">
    <thead>
        <tr>
            <th>Id</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Age</th>
            <th>Address</th>
            <th>Mobile</th>
            <th>Details</th>
            <th>Edit</th>
            <th>Delete</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.FirstName</td>
                <td>@item.LastName</td>
                <td>@item.Age</td>
                <td>@item.Address</td>
                <td>@item.Mobile</td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> 
                </td>
                <td>
                    <a asp-action="Update" asp-route-id="@item.Id">Edit</a>     
                </td>
                <td>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                          onsubmit="return confirm('Are you sure you want to delete?');">

                        <button type="submit">Delete</button>

                    </form>
                </td>
            </tr>
        }

    </tbody>
</table>